# =============================================================================
# DjangoTestProject – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
# Generiere einen sicheren Key z.B. mit:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-use-a-real-secret-key-in-production

DEBUG=false

# Kommagetrennte Liste erlaubter Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example.com

# Deployment-Umgebung (development | staging | production)
ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Datenbank (PostgreSQL)
# ---------------------------------------------------------------------------
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://django:django@db:5432/djangotestproject

# Für docker-compose: einzelne Variablen (werden in DATABASE_URL zusammengesetzt)
POSTGRES_DB=djangotestproject
POSTGRES_USER=django
POSTGRES_PASSWORD=django

# Maximale Connection-Lifetime in Sekunden (0 = keine Persistenz)
DB_CONN_MAX_AGE=60

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8000

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=sync
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=20
GUNICORN_KEEP_ALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Sicherheit (nur in Produktion relevant)
# ---------------------------------------------------------------------------
SECURE_SSL_REDIRECT=true

# ---------------------------------------------------------------------------
# OpenTelemetry
# ---------------------------------------------------------------------------
# Aktiviert OTEL Tracing + Loki-Logging (true/false)
OTEL_ENABLED=false

# Service-Identifikation
OTEL_SERVICE_NAME=djangotestproject
OTEL_SERVICE_VERSION=0.1.0

# OTLP Endpoint (OTEL Collector oder direkt Tempo)
# Beispiel Homelab: OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Metrics-Exporter: "prometheus" (Scrape via /metrics) oder "otlp"
OTEL_METRICS_EXPORTER=prometheus

# ---------------------------------------------------------------------------
# Loki (Logs)
# ---------------------------------------------------------------------------
# Loki Push-API Endpoint
# Beispiel Homelab: LOKI_URL=http://loki.homelab.local:3100/loki/api/v1/push
LOKI_URL=

# Optional: Loki Basic Auth (falls konfiguriert)
LOKI_USERNAME=
LOKI_PASSWORD=

# Für lokalen OTEL Collector → Homelab Weiterleitung
LOKI_ENDPOINT=http://loki.homelab.local:3100/loki/api/v1/push

# ---------------------------------------------------------------------------
# Tempo (Traces) – nur für OTEL Collector Konfiguration
# ---------------------------------------------------------------------------
TEMPO_ENDPOINT=tempo.homelab.local:4317

# ---------------------------------------------------------------------------
# Prometheus – nur für OTEL Collector Konfiguration
# ---------------------------------------------------------------------------
PROMETHEUS_REMOTE_WRITE_URL=http://prometheus.homelab.local:9090/api/v1/write

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
DB_LOG_LEVEL=WARNING

# ---------------------------------------------------------------------------
# Optionaler Admin-Superuser (wird beim ersten Start angelegt)
# ---------------------------------------------------------------------------
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
